{
  "name": "coin-guard",
  "version": "1.1.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "web:dev": "turbo run dev --filter=@coin-guard/web",
    "web:build": "turbo run build --filter=@coin-guard/web",
    "format": "turbo run format",
    "format:fix": "turbo run format:fix",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@coin-guard/db",
    "db:migrate": "turbo run db:migrate --filter=@coin-guard/db --",
    "shadcn": "turbo run shadcn --filter=@coin-guard/ui --",
    "shadcn:add": "turbo run shadcn:add --filter=@coin-guard/ui --"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "turbo": "^2.10.5",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  }
}
