{
  "extends": "@coin-guard/ts-config/nextjs.json",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "@/*": ["./src/*"],
      "@/ui/*": ["./src/components/ui/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.js",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
