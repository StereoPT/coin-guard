{
  "name": "@coin-guard/ui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "shadcn": "pnpm --filter @coin-guard/ui exec shadcn",
    "shadcn:add": "pnpm --filter @coin-guard/ui exec shadcn add",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "lint": "biome lint .",
    "lint:fix": "biome lint . --write",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles/globals.css",
    "./tailwind-source.css": "./src/styles/tailwind-source.css",
    "./lib/utils": "./src/lib/utils.ts",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/use-mobile": "./src/hooks/use-mobile.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./icons": "./src/icons.ts",
    "./charts": "./src/charts.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@shadcn/react": "^0.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.26.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^10.0.1",
    "react-dropzone": "^19.1.1",
    "react-resizable-panels": "^4.12.2",
    "recharts": "3.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "peerDependencies": {
    "react": "^19.2.8",
    "react-dom": "^19.2.8"
  },
  "devDependencies": {
    "@coin-guard/biome-config": "workspace:^",
    "@coin-guard/ts-config": "workspace:*",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "shadcn": "^4.14.0",
    "typescript": "catalog:"
  }
}
